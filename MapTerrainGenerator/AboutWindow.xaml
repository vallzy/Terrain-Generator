<Window x:Class="MapTerrainGeneratorWPF.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="440" Width="500" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FFF5F5F5"
        Icon="/Assets/favicon.ico">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="87*"/>
            <ColumnDefinition Width="413*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF222222" Padding="20" Grid.ColumnSpan="2" Margin="0,0,0,962">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="Assets/icon.png" Width="72" Height="72" Margin="0,0,20,0" RenderOptions.BitmapScalingMode="HighQuality"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Radiant Terrain Generator" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Version 1.2.0" FontSize="12" Foreground="#FFCCCCCC" Margin="0,2,0,0"/>
                    <TextBlock Text="Procedural CSG generation tool for id Tech 3 engines." FontSize="14" Foreground="#FFAAAAAA" Margin="8,0,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Margin="20,166,20,0" VerticalAlignment="Top" Grid.ColumnSpan="2">
            <TextBlock Text="Developed by" FontSize="16" FontWeight="SemiBold" Foreground="#FF666666" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="https://avatars.githubusercontent.com/u/45981588?v=4" Width="64" Height="64" Margin="0,0,0,10" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Vallz" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center">
                        <Hyperlink NavigateUri="https://github.com/vallzy" RequestNavigate="Hyperlink_RequestNavigate">
                            GitHub Profile
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="1" Background="#FFDDDDDD" Margin="0,5"/>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="https://avatars.githubusercontent.com/u/33007360?v=4" Width="64" Height="64" Margin="0,0,0,10" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="vld" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/vldvoiculescu" RequestNavigate="Hyperlink_RequestNavigate">
                        GitHub Profile
                    </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </StackPanel>

        <Border Background="#FFEAEAEA" BorderBrush="#FFDDDDDD" BorderThickness="0,1,0,0" Padding="15" Grid.ColumnSpan="2" Margin="0,357,0,670">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Foreground="#FF555555">
                    <Run Text="Open Source on "/>
                    <Hyperlink NavigateUri="https://github.com/vallzy/Terrain-Generator" RequestNavigate="Hyperlink_RequestNavigate" FontWeight="Bold">
                        GitHub
                    </Hyperlink>
                </TextBlock>
                <TextBlock Text=" | " Foreground="#FFBBBBBB" Margin="10,0"/>
                <TextBlock VerticalAlignment="Center" Foreground="#FF555555">
                    <Hyperlink NavigateUri="https://github.com/vallzy/Terrain-Generator/issues" RequestNavigate="Hyperlink_RequestNavigate">
                        Report a Bug
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>